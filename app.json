{
  "expo": {
    "name": "MeetMind",
    "slug": "meetmind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "meetmind",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MeetMind needs microphone access to transcribe meeting audio in real-time.",
        "NSSpeechRecognitionUsageDescription": "MeetMind uses speech recognition to convert audio to text."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": ["RECORD_AUDIO"],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "MeetMind needs microphone access to transcribe meeting audio."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
